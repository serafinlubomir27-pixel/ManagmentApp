# ManagmentApp — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit it with real credentials.

# ---------------------------------------------------------------------------
# Database backend: "sqlite" (default, local) or "postgres" (Supabase/cloud)
# ---------------------------------------------------------------------------
DB_BACKEND=sqlite

# ---------------------------------------------------------------------------
# SQLite — local development (used when DB_BACKEND=sqlite)
# ---------------------------------------------------------------------------
# Path is relative to project root, default: my_project_app.db
SQLITE_PATH=my_project_app.db

# ---------------------------------------------------------------------------
# PostgreSQL / Supabase (used when DB_BACKEND=postgres)
# ---------------------------------------------------------------------------
# Find this in your Supabase project:
#   Settings → Database → Connection string → URI (mode: Transaction)
#
# Format: postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres
#
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Supabase Realtime (frontend — WebSocket live updates)
# Nájdeš v Supabase Dashboard → Settings → API
# ---------------------------------------------------------------------------
# Project URL (napr. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon/public key — bezpečné pre frontend (Row Level Security chráni dáta)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# AI (Pilier 1 — pripravené, aktivuje sa pridaním kľúča)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
